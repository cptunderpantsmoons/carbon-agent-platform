# Railway
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_TEAM_ID=
RAILWAY_ENVIRONMENT_ID=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carbon_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Admin Agent
ADMIN_AGENT_API_KEY=
ADMIN_AGENT_WEBHOOK_URL=

# Open WebUI
OPEN_WEBUI_SECRET_KEY=
OPEN_WEBUI_ADMIN_EMAIL=admin@example.com
OPEN_WEBUI_ADMIN_PASSWORD=

# LLM Provider
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL_NAME=

# Agent Template
AGENT_DOCKER_IMAGE=carbon-agent-adapter:latest
AGENT_DEFAULT_MEMORY=1GB
AGENT_DEFAULT_CPU=1

# Session
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24
SESSION_SPINUP_TIMEOUT_SECONDS=120

# Volumes
VOLUME_SIZE_GB=5
VOLUME_MOUNT_PATH=/data
