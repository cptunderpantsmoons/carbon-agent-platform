# ===========================================
# Carbon Agent Platform - Environment Variables
# ===========================================

# PostgreSQL Database
POSTGRES_PASSWORD=your-secure-password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Orchestrator
ORCHESTRATOR_PORT=8000
ADMIN_AGENT_API_KEY=your-admin-api-key-here
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24

# Railway API (Get from https://railway.app/account/tokens)
RAILWAY_API_TOKEN=your-railway-api-token
RAILWAY_PROJECT_ID=your-project-id
RAILWAY_TEAM_ID=your-team-id
RAILWAY_ENVIRONMENT_ID=your-environment-id

# Adapter
ADAPTER_PORT=8001
AGENT_API_URL=http://agent-zero:5000
AGENT_API_KEY=your-agent-api-key
MODEL_NAME=carbon-agent

# Open WebUI
WEBUI_PORT=3000
OPENWEBUI_API_KEY=sk-your-openai-api-key
WEBUI_SECRET=your-webui-secret-key

# Agent Configuration
AGENT_DOCKER_IMAGE=carbon-agent-adapter:latest
