# ===========================================
# Carbon Agent Platform - Environment Variables
# ===========================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-password-change-in-prod
POSTGRES_DB=carbon_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:dev-password-change-in-prod@postgres:5432/carbon_platform

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Orchestrator
ORCHESTRATOR_PORT=8000
ADMIN_AGENT_API_KEY=dev-admin-key-change-in-prod
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24

# Docker (self-hosted PaaS)
AGENT_DOCKER_IMAGE=carbon-agent-adapter:latest
AGENT_MEMORY_LIMIT=512m
AGENT_CPU_NANOS=500000000
DOCKER_NETWORK=carbon-agent-net

# Traefik (reverse proxy)
AGENT_DOMAIN=agents.carbon.dev
TRAEFIK_ENTRYPOINT=websecure
AGENT_BASE_PATH=/agent

# Adapter
ADAPTER_PORT=8001
AGENT_API_URL=http://agent-zero:5000
AGENT_API_KEY=
MODEL_NAME=carbon-agent

# Open WebUI
WEBUI_PORT=3000
OPENWEBUI_API_KEY=sk-dev-test-key
WEBUI_SECRET=dev-secret-change-in-prod

# Clerk Authentication (required for production)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWT_PUBLIC_KEY=
CLERK_FRONTEND_API_URL=

# Optional: issuer URL for JWT verification (enables iss claim check in production)
# Leave empty for dev; set to https://your-app.clerk.accounts.dev in production
CLERK_JWT_ISSUER=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001

# Rate Limiting Storage URI
# memory://   in-process, resets on restart (dev/test)
# redis://..  persists across restarts, shared across replicas (production)
RATE_LIMIT_STORAGE_URI=memory://

# Scheduler
HEALTH_CHECK_INTERVAL_MINUTES=5
ANALYTICS_INTERVAL_MINUTES=60
AUDIT_CLEANUP_INTERVAL_HOURS=24
AUDIT_RETENTION_DAYS=90
DB_HEALTH_CHECK_INTERVAL_MINUTES=10

# Session
SESSION_SPINUP_TIMEOUT_SECONDS=120

# Obot MCP Gateway (optional — for tool-augmented AI agents)
# See docs/MCP_INTEGRATION_GUIDE.md for complete setup instructions
OBOT_PORT=8080
MCP_ENABLED=false
MCP_GATEWAY_URL=http://obot-gateway:8080
MCP_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=3

# LLM Provider Keys (required for obot MCP features)
# At least one of these must be set if MCP_ENABLED=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Obot Security (CHANGE IN PRODUCTION)
# Generate with: openssl rand -base64 32
OBOT_ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Deployment
AUTO_CREATE_TABLES=true