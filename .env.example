# ===========================================
# Carbon Agent Platform - Environment Variables
# ===========================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-password-change-in-prod
POSTGRES_DB=carbon_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:dev-password-change-in-prod@postgres:5432/carbon_platform

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Orchestrator
ORCHESTRATOR_PORT=8000
ADMIN_AGENT_API_KEY=dev-admin-key-change-in-prod
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24

# Docker (self-hosted PaaS)
AGENT_DOCKER_IMAGE=carbon-agent-adapter:latest
AGENT_MEMORY_LIMIT=512m
AGENT_CPU_NANOS=500000000
DOCKER_NETWORK=carbon-agent-net

# Traefik (reverse proxy)
AGENT_DOMAIN=agents.carbon.dev
TRAEFIK_ENTRYPOINT=websecure
AGENT_BASE_PATH=/agent

# Adapter
ADAPTER_PORT=8001
AGENT_API_URL=http://agent-zero:5000
AGENT_API_KEY=
MODEL_NAME=carbon-agent

# LLM Provider Configuration
# Supported providers: agent-zero (default), openai, featherless, deepseek, anthropic
# Switch providers by changing LLM_PROVIDER value
LLM_PROVIDER=agent-zero
LLM_BASE_URL=http://localhost:5000
LLM_API_KEY=
LLM_MODEL_NAME=carbon-agent

# OpenAI Provider Settings (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL_NAME=gpt-4o

# Featherless AI Provider Settings (when LLM_PROVIDER=featherless)
# Get API key from: https://featherless.ai
# Featherless uses OpenAI-compatible API with open-source models
# FEATHERLESS_API_KEY=your-featherless-key-here
# LLM_MODEL_NAME=meta-llama-3.1-70b-instruct

# DeepSeek Provider Settings (when LLM_PROVIDER=deepseek)
# Get API key from: https://platform.deepseek.com
# DeepSeek uses OpenAI-compatible API with powerful coding/reasoning models
# DEEPSEEK_API_KEY=your-deepseek-key-here
# LLM_MODEL_NAME=deepseek-chat  # or deepseek-coder for code tasks

# Anthropic Provider Settings (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_MODEL_NAME=claude-3-sonnet-20240229

# LLM Temperature Settings (DeepSeek recommendations)
# Coding/Math: 0.0 | Data Analysis: 1.0 | General Chat: 1.3 | Creative: 1.5
LLM_TEMPERATURE=1.0

# Open WebUI
WEBUI_PORT=3000
OPENWEBUI_API_KEY=sk-dev-test-key
WEBUI_SECRET=dev-secret-change-in-prod
OPENWEBUI_CLERK_ENABLED=true
WEBUI_ADMIN_EMAIL=admin@carbon.local
WEBUI_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WEBUI_ADMIN_NAME=Carbon Admin
NEXT_PUBLIC_HUB_ADMIN_EMAIL=admin@carbon.local
DASHBOARD_PORT=3001

# Clerk Authentication (required for production)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWT_PUBLIC_KEY=
CLERK_FRONTEND_API_URL=

# Optional: issuer URL for JWT verification (enables iss claim check in production)
# Leave empty for dev; set to https://your-app.clerk.accounts.dev in production
CLERK_JWT_ISSUER=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8000,http://localhost:8001

# Contract Hub (separate app in the shared deployment)
CONTRACT_HUB_PATH=../contract-hub
CONTRACT_HUB_PORT=3002
CONTRACT_HUB_POSTGRES_PORT=5433
CONTRACT_HUB_POSTGRES_PASSWORD=contracthub
CONTRACT_HUB_TENANT_ID=contract-hub-tenant
CONTRACT_HUB_DOCASSEMBLE_URL=
CONTRACT_HUB_DOCASSEMBLE_API_KEY=
CONTRACT_HUB_OPENCODE_SERVER_URL=
CONTRACT_HUB_OPENCODE_API_KEY=

# Model provider keys for the Intelligence Hub dashboard
FEATHERLESS_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Admin Agent over SSH (dashboard -> platform host)
ADMIN_AGENT_ENABLED=false
ADMIN_AGENT_SSH_TARGET=
ADMIN_AGENT_CONTROL_TOKEN=
ADMIN_AGENT_TIMEOUT_SECONDS=90
ADMIN_AGENT_REMOTE_DIR=/opt/carbon-agent-platform
ADMIN_AGENT_ALLOWED_SERVICES=orchestrator,adapter,open-webui,dashboard,vector-store,contract-hub,contract-hub-postgres,postgres,redis,chromadb

# RAG Gateway
RAG_FIXED_TENANT_ID=contract-hub-tenant
VECTOR_STORE_URL=http://vector-store:8000

# Rate Limiting Storage URI
# memory://   in-process, resets on restart (dev/test)
# redis://..  persists across restarts, shared across replicas (production)
RATE_LIMIT_STORAGE_URI=memory://

# Scheduler
HEALTH_CHECK_INTERVAL_MINUTES=5
ANALYTICS_INTERVAL_MINUTES=60
AUDIT_CLEANUP_INTERVAL_HOURS=24
AUDIT_RETENTION_DAYS=90
DB_HEALTH_CHECK_INTERVAL_MINUTES=10

# Session
SESSION_SPINUP_TIMEOUT_SECONDS=120



# Deployment
AUTO_CREATE_TABLES=true
