# =============================================================================
# Carbon Agent Platform - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in all values before deploying
#
# SECURITY: Never commit actual secrets to version control.
# Use a secrets management system in production (Vault, AWS Secrets Manager, etc.)
# =============================================================================

# Database Configuration
# These are REQUIRED for production
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE_MIN_32_CHARS
POSTGRES_USER=postgres
POSTGRES_DB=carbon_platform
POSTGRES_PORT=5432

# Redis Configuration
# Set a strong password for production
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_MIN_32_CHARS
REDIS_PORT=6379

# Clerk Authentication (Required)
# Get these from https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_live_YOUR_SECRET_KEY
CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
CLERK_FRONTEND_API_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev

# Admin API Configuration (Required)
# Generate a strong random string for admin API key
ADMIN_AGENT_API_KEY=YOUR_ADMIN_API_KEY_MIN_32_CHARS

# Agent Configuration (Required)
# The Docker image must be built and available locally or in a registry
AGENT_DOCKER_IMAGE=carbon-agent-adapter:latest
AGENT_API_URL=http://YOUR_AGENT_ZERO_ENDPOINT
AGENT_API_KEY=YOUR_AGENT_ZERO_API_KEY
AGENT_DOMAIN=agents.example.com

# Resource Limits (Optional, defaults shown)
AGENT_MEMORY_LIMIT=512m
AGENT_CPU_NANOS=500000000

# Ports (Optional, defaults shown)
ORCHESTRATOR_PORT=8000
ADAPTER_PORT=8001
WEBUI_PORT=3000
DASHBOARD_PORT=3001
CONTRACT_HUB_PORT=3002
CONTRACT_HUB_POSTGRES_PORT=5433
CHROMADB_PORT=8002
VECTOR_STORE_PORT=8003

# Session Configuration (Optional)
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24

# Open WebUI Configuration (Required)
OPENWEBUI_API_KEY=YOUR_OPENWEBUI_API_KEY
WEBUI_SECRET=YOUR_WEBUI_SECRET_MIN_32_CHARS
OPENWEBUI_CLERK_ENABLED=true
WEBUI_ADMIN_EMAIL=admin@carbon.local
WEBUI_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WEBUI_ADMIN_NAME=Carbon Admin
NEXT_PUBLIC_HUB_ADMIN_EMAIL=admin@carbon.local
WEBUI_CORS_ORIGIN=https://YOUR_DOMAIN.com

# Embedding Model (Optional, default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_COLLECTION_NAME=carbon_documents

# Model Configuration (Optional)
MODEL_NAME=carbon-agent

# CORS Configuration (Required)
# Comma-separated list of allowed origins for your frontend/dashboard
CORS_ALLOWED_ORIGINS=https://agents.example.com,https://YOUR_DOMAIN.com,https://contract-hub.example.com

# Contract Hub deployment
CONTRACT_HUB_PATH=../contract-hub
CONTRACT_HUB_POSTGRES_PASSWORD=YOUR_CONTRACT_HUB_DB_PASSWORD_MIN_32_CHARS
CONTRACT_HUB_TENANT_ID=contract-hub-tenant
CONTRACT_HUB_DOCASSEMBLE_URL=
CONTRACT_HUB_DOCASSEMBLE_API_KEY=
CONTRACT_HUB_OPENCODE_SERVER_URL=
CONTRACT_HUB_OPENCODE_API_KEY=

# Model provider keys for the Intelligence Hub dashboard
FEATHERLESS_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Admin Agent over SSH (dashboard -> platform host)
ADMIN_AGENT_ENABLED=true
ADMIN_AGENT_SSH_TARGET=
ADMIN_AGENT_CONTROL_TOKEN=
ADMIN_AGENT_TIMEOUT_SECONDS=90
ADMIN_AGENT_REMOTE_DIR=/opt/carbon-agent-platform
ADMIN_AGENT_ALLOWED_SERVICES=orchestrator,adapter,open-webui,dashboard,vector-store,contract-hub,contract-hub-postgres,postgres,redis,chromadb

# =============================================================================
# Helper Commands
# =============================================================================
# Generate strong passwords:
#   openssl rand -base64 32
#
# Test configuration before deploying:
#   docker compose -f docker-compose.prod.yml config
#
# Verify all required variables are set:
#   grep '${.*:?' docker-compose.prod.yml | grep -oP '(?<=\$\{)[^}]+' | sort -u
# =============================================================================
