# ===========================================
# Production Environment Configuration
# ===========================================

# PostgreSQL
POSTGRES_PASSWORD=<generate-secure-password>
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Orchestrator
ORCHESTRATOR_PORT=8000
ADMIN_AGENT_API_KEY=<generate-secure-admin-key>

# Railway (Required for service management)
RAILWAY_API_TOKEN=<get-from-railway-dashboard>
RAILWAY_PROJECT_ID=<get-from-railway-dashboard>
RAILWAY_TEAM_ID=<get-from-railway-dashboard>
RAILWAY_ENVIRONMENT_ID=<get-from-railway-dashboard>

# Session Management
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24

# Adapter
ADAPTER_PORT=8001
AGENT_API_KEY=<your-agent-zero-api-key>

# Open WebUI
WEBUI_PORT=3000
OPENWEBUI_API_KEY=<your-openai-api-key>
WEBUI_SECRET=<generate-secure-webui-secret>

# Open WebUI - Clerk Integration (Production)
OPENWEBUI_CLERK_ENABLED=true
CLERK_PUBLISHABLE_KEY=<get-from-clerk-dashboard>
CLERK_SECRET_KEY=<get-from-clerk-dashboard>
CLERK_FRONTEND_API_URL=https://your-tenant.clerk.accounts.dev

# Open WebUI - Custom Theme
OPENWEBUI_CUSTOM_THEME=true

# Agent
AGENT_DOCKER_IMAGE=ghcr.io/your-org/carbon-agent-adapter:latest
