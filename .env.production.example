# ===========================================
# Production Environment Configuration
# ===========================================
# ⚠️ NEVER commit real credentials! Use secrets manager.
# ===========================================

# PostgreSQL
POSTGRES_USER=carbon_admin
POSTGRES_PASSWORD=<generate-secure-password>
POSTGRES_DB=carbon_platform
DATABASE_URL=postgresql://carbon_admin:<password>@your-postgres-host:5432/carbon_platform

# Redis
REDIS_URL=redis://your-redis-host:6379/0

# Orchestrator
ORCHESTRATOR_PORT=8000
ADMIN_AGENT_API_KEY=<generate-secure-admin-key>

# Docker (self-hosted PaaS)
DOCKER_NETWORK=carbon-agent-net
AGENT_DOCKER_IMAGE=ghcr.io/your-org/carbon-agent-adapter:latest
AGENT_MEMORY_LIMIT=512m
AGENT_CPU_NANOS=500000000
ADAPTER_PORT=8001

# Traefik
AGENT_DOMAIN=agents.carbon.dev
TRAEFIK_ENTRYPOINT=websecure
AGENT_BASE_PATH=/agent

# Session Management
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_HOURS=24
SESSION_SPINUP_TIMEOUT_SECONDS=120

# Agent Zero
AGENT_API_URL=
AGENT_API_KEY=

# LLM
MODEL_NAME=carbon-agent

# Context Store (Redis)
REDIS_CONTEXT_DB=1

# Adapter
OPENWEBUI_API_KEY=sk-prod-$(openssl rand -hex 24)

# Open WebUI
WEBUI_PORT=3000
WEBUI_SECRET=<generate-secure-webui-secret>

# Open WebUI - Clerk Integration (Production)
OPENWEBUI_CLERK_ENABLED=true
CLERK_PUBLISHABLE_KEY=<get-from-clerk-dashboard>
CLERK_SECRET_KEY=<get-from-clerk-dashboard>
CLERK_FRONTEND_API_URL=https://your-tenant.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...<get-from-clerk-webhooks>

# ⚠️ REQUIRED: Set issuer URL for JWT verification (enables iss claim check)
# Format: https://your-tenant.clerk.accounts.dev
CLERK_JWT_ISSUER=https://your-tenant.clerk.accounts.dev

# CORS — ⚠️ REQUIRED: Set your production domain(s)
CORS_ALLOWED_ORIGINS=https://agents.carbon.dev

# Rate Limiting — Redis for cross-replica persistence
RATE_LIMIT_STORAGE_URI=redis://your-redis-host:6379/0

# Scheduler
HEALTH_CHECK_INTERVAL_MINUTES=5
ANALYTICS_INTERVAL_MINUTES=60
AUDIT_CLEANUP_INTERVAL_HOURS=24
AUDIT_RETENTION_DAYS=90
DB_HEALTH_CHECK_INTERVAL_MINUTES=10

# Deployment — ⚠️ MUST be false in production (use Alembic migrations)
AUTO_CREATE_TABLES=false
