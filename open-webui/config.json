{
  "openai": {
    "api_base_url": "http://adapter:8000/v1",
    "api_key": "{{USER_API_KEY}}",
    "model_name": "carbon-agent"
  },
  "ui": {
    "title": "The Intelligence Hub",
    "description": "Your personal AI workspace powered by Carbon Agent",
    "logo": "/static/logo.png",
    "theme": {
      "primary_color": "#00D4AA",
      "secondary_color": "#1A1A2E",
      "accent_color": "#16213E",
      "background_color": "#0F0F23",
      "text_color": "#E0E0E0",
      "font_family": "Inter, system-ui, -apple-system, sans-serif",
      "custom_css": "/static/custom-theme.css"
    },
    "branding": {
      "favicon": "/static/favicon.ico",
      "welcome_message": "Welcome to The Intelligence Hub",
      "footer_text": "Powered by Carbon Agent Platform",
      "show_logo_in_header": true,
      "show_footer": true
    }
  },
  "features": {
    "signup_enabled": false,
    "default_user_role": "user",
    "admin_only": false,
    "web_search": true,
    "image_generation": false,
    "code_execution": true,
    "file_upload": true,
    "conversations_history": true,
    "shared_conversations": false,
    "custom_system_prompts": true
  },
  "auth": {
    "type": "clerk",
    "clerk_enabled": true,
    "admin_email": "admin@example.com",
    "jwt_validation": true,
    "auto_create_users": true,
    "session_refresh_interval": 300
  },
  "clerk": {
    "publishable_key": "{{CLERK_PUBLISHABLE_KEY}}",
    "api_url": "https://api.clerk.com",
    "frontend_api_url": "{{CLERK_FRONTEND_API_URL}}",
    "sync_user_profile": true,
    "auto_inject_api_key": true
  },
  "proxy": {
    "adapter_url": "http://adapter:8000",
    "orchestrator_url": "http://orchestrator:8000",
    "timeout_seconds": 120,
    "retry_attempts": 3,
    "cors_enabled": true,
    "allowed_origins": ["*"]
  }
}
