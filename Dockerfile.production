# Multi-stage production Dockerfile
FROM python:3.12-slim AS base

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends /
    curl /
    tini /
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Stage 1: Orchestrator
FROM base AS orchestrator
COPY orchestrator/requirements.txt /app/orchestrator/
RUN pip install --no-cache-dir -r /app/orchestrator/requirements.txt
COPY orchestrator/app/ /app/orchestrator/app/
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 /
  CMD curl -f http://localhost:8000/health || exit 1
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["uvicorn", "orchestrator.app.main:app", "--host", "0.0.0.0", "--port", "8000"]

# Stage 2: Adapter
FROM base AS adapter
COPY adapter/requirements.txt /app/adapter/
RUN pip install --no-cache-dir -r /app/adapter/requirements.txt
COPY adapter/app/ /app/adapter/app/
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 /
  CMD curl -f http://localhost:8000/health || exit 1
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["uvicorn", "adapter.app.main:app", "--host", "0.0.0.0", "--port", "8000"]
